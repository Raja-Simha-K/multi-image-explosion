<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Multi Image Explosion</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  body{
      font-family: "Instrument Serif", serif;
      background-color: #111111;
      color: #ffffff;
  }

  .section {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 64px;
  }

  .image-section {
    height: 500vh;
  }

  .image-wrapper {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .image-stack {
    position: relative;
    width: 50%;
    height: 70vh;
  }

  .image-item {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
  }

  .image-item img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  .image-text{
    font-size: 64px;
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 99;
  }
  .image-item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }
</style>
</head>
<body>

<div class="section top">
  <p>Welcome to the code</p>
</div>

<div class="image-section">
  <div class="image-wrapper">
    <div class="image-stack">

        <div class="image-item"><img src="https://picsum.photos/400/225?random=1"></div>
        <div class="image-item"><img src="https://picsum.photos/400/225?random=2"></div>
        <div class="image-item"><img src="https://picsum.photos/400/225?random=3"></div>
        <div class="image-item"><img src="https://picsum.photos/400/225?random=4"></div>
        <div class="image-item"><img src="https://picsum.photos/400/225?random=5"></div>
        <div class="image-item"><img src="https://picsum.photos/400/225?random=6"></div>
        <div class="image-item"><img src="https://picsum.photos/400/225?random=7"></div>
        <div class="image-item"><img src="https://picsum.photos/400/225?random=8"></div>
        <div class="image-item"><img src="https://picsum.photos/400/225?random=9"></div>

        <!-- ✅ LAST ITEM = VIDEO -->
        <div class="image-item video-item">
          <video 
            src="https://www.pexels.com/download/video/31883946/" 
            autoplay 
            muted 
            loop 
            playsinline>
          </video>
        </div>

      </div>
    <div class="image-text">
      <p>Scroll until the end</p>
    </div>
  </div>
</div>

<div class="section bottom">
  <p>Section has been ended</p>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script>
gsap.registerPlugin(ScrollTrigger);

// ✅ Now targeting wrapper divs
const items = gsap.utils.toArray(".image-item");

// ✅ Stack order
items.forEach((item, i) => {
  item.style.zIndex = items.length - i;
});

// ✅ Directions
const directions = [
  { x: -0.8, y: 1 },
  { x: 1, y: -1 },
  { x: -1, y: -1 },
  { x: 1, y: 1 },
  { x: -1, y: -0.8 },
  { x: 1, y: 1 },
  { x: 0.8, y: -1 },
  { x: -1, y: -1 },
  { x: 1, y: -1 },
  { x: -1, y: 1 }
];

// ✅ Initial state
gsap.set(items, {
  scale: 0,
  x: 0,
  y: 0,
  transformOrigin: "center center",
  willChange: "transform"
});

// ✅ Animation
gsap.to(items, {
  scrollTrigger: {
    trigger: ".image-section",
    start: "top top",
    end: "bottom bottom",
    scrub: 1,
    pin: ".image-wrapper",
    anticipatePin: 1,
    invalidateOnRefresh: true,
  },
  

  scale: (i) => {
    if (i === items.length - 1) {
      const el = items[i].querySelector("img, video");

      return Math.max(
        window.innerWidth / el.offsetWidth,
        window.innerHeight / el.offsetHeight
      );
    }
    return 1.2;
  },

  x: (i) => {
    if (i === items.length - 1) return 0;
    return window.innerWidth * directions[i % directions.length].x;
  },

  y: (i) => {
    if (i === items.length - 1) return 0;
    return window.innerHeight * directions[i % directions.length].y;
  },

  zIndex: (i) => (i === items.length - 1 ? 999 : items.length - i),

  stagger: {
    each: 0.05,
  },

  ease: "power2.out"
});


// ✅ Resize fix
window.addEventListener("resize", () => {
  ScrollTrigger.refresh();
});
</script>

</body>
</html>
